# =========================================================================
# 가르침에듀 레벨 테스트 환경변수
# =========================================================================
# 이 파일을 ".env.local" 로 복사한 뒤 실제 값을 채워 넣으세요.
# .env.local 은 절대 git 에 올리지 마세요 (.gitignore 에 이미 포함됨).
# =========================================================================

# Supabase 프로젝트 URL
# 대시보드 → Project Settings → API → "Project URL" 에서 복사
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxx.supabase.co

# Supabase anon/public API 키
# 대시보드 → Project Settings → API → "anon public" 에서 복사
# (이 키는 클라이언트에 노출돼도 안전합니다. RLS 로 보호되니까요.)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGci...
